{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "outDir": "./out",
    "rootDir": "./src",
    "esModuleInterop": true,
    "sourceMap": true,
    "strict": true,
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022",
      "DOM"
    ]
  },
  "include": [
    "src/**/*"
  ]
}