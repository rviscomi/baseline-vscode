{
  "name": "baseline-vscode",
  "displayName": "Baseline",
  "description": "Search for web platform features and view their Baseline browser support status directly in your editor.",
  "version": "0.0.6",
  "publisher": "rviscomi",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/rviscomi/baseline-vscode"
  },
  "homepage": "https://github.com/rviscomi/baseline-vscode#readme",
  "bugs": {
    "url": "https://github.com/rviscomi/baseline-vscode/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "baseline",
    "web features",
    "web platform",
    "browser compatibility",
    "mdn"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:html",
    "onLanguage:css",
    "onLanguage:scss",
    "onLanguage:less",
    "onLanguage:vue",
    "onLanguage:svelte",
    "onLanguage:astro",
    "onLanguage:markdown",
    "onLanguage:mdx",
    "onLanguage:yaml",
    "onLanguage:json",
    "onLanguage:jsonc"
  ],
  "icon": "img/icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "baseline-vscode.baselineSearch",
        "title": "Baseline search"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -watch -p ./",
    "lint": "eslint .",
    "package": "npx vsce package",
    "publish": "npx dotenv -e .env -- ovsx publish",
    "pretest": "npm run compile && npm run lint",
    "test": "vscode-test"
  },
  "dependencies": {
    "web-features": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "ovsx": "^0.10.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
